{
	"name": "lucus",
	"description": "CDN for dev environment. A local server alternative to Cloudflare/Cloudinary image transformations",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start": "node dist/main.js",
		"start:cli": "node dist/cli/main.js",
		"dev:cli": "tsx src/cli/main.ts",
		"dev": "tsx src/main.ts | pino-pretty",
		"build": "rm -fr dist && npm run build:js && npm run copy:assets",
		"build:js": "tsup src/index.ts src/main.ts src/cli/main.ts --format esm --out-dir dist",
		"build:styles": "npx @tailwindcss/cli -i ./src/styles.css -o ./public/assets/styles.css",
		"copy:assets": "cp -fr src/utils/templates dist/templates && cp -fr src/utils/public dist/public",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=22"
	},
	"bin": {
		"lucus": "dist/cli/main.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"dependencies": {
		"commander": "^14.0.3",
		"express": "^5.2.1",
		"http-status": "^2.1.0",
		"mime": "^4.1.0",
		"pino": "^10.3.1",
		"redis": "^5.11.0",
		"sharp": "^0.34.5",
		"varlock": "^0.6.2"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.11",
		"eslint": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"tailwindcss": "^4.2.2",
		"tsc-esm-fix": "^3.1.2",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "5.9.3"
	}
}
